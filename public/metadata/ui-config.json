    },
    {
        "id": "table-demo",
        "component": "dynamic-table",
        "url": "/public/plugins/table/DynamicTable.js",
        "props": {
            "tableData": {
                "columns": [
                    {
                        "field": "id",
                        "header": "ID",
                        "sortable": false
                    },
                    {
                        "field": "name",
                        "header": "Employee Name",
                        "render": "<div style=\"font-weight:500;\">${name}</div><div style=\"font-size:12px;color:#64748b\">${email}</div>"
                    },
                    {
                        "field": "role",
                        "header": "Role"
                    },
                    {
                        "field": "department",
                        "header": "Department"
                    },
                    {
                        "field": "status",
                        "header": "Status",
                        "render": "<span class=\"et-badge\" badge-status=\"${status}\">${status}</span>"
                    },
                    {
                        "field": "joinDate",
                        "header": "Join Date"
                    }
                ]
            },
            "config": {
                "title": "Employee Directory",
                "pageSize": 10,
                "sortable": true,
                "selectable": true,
                "searchable": true,
                "actions": [
                    "view",
                    "edit",
                    "delete",
                    "create"
                ]
            },
            "rootId": "table-root"
        }
    },
